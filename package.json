{
  "name": "poe2-price-overlay",
  "version": "2.3.0",
  "description": "Hotkey-toggled currency price overlay for Path of Exile 2 - live rates, arbitrage signals, 7d trends",
  "main": "main.js",
  "scripts": {
    "build:item": "node scripts/build-item-tab.mjs",
    "prestart": "node scripts/build-item-tab.mjs",
    "start": "electron .",
    "predist": "node scripts/build-item-tab.mjs",
    "dist": "electron-builder --win nsis"
  },
  "build": {
    "appId": "com.poe2vibetools.overlay",
    "productName": "POE2 Currency Overlay",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "focus-native.js",
      "preload.js",
      "trade2.js",
      "cx-feed.js",
      "cx-map.json",
      "renderer/**",
      "app.ico",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "app.ico"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "POE2-VibeTools",
        "repo": "poe2-currency-overlay"
      }
    ],
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true,
      "artifactName": "POE2-Currency-Overlay-Setup.exe",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "npmRebuild": false
  },
  "author": "POE2 VibeTools",
  "license": "GPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/POE2-VibeTools/poe2-currency-overlay.git"
  },
  "devDependencies": {
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1"
  },
  "dependencies": {
    "@sindresorhus/fnv1a": "^3.1.0",
    "dot-prop": "^10.1.0",
    "electron-updater": "^6.8.9",
    "koffi": "^3.1.2",
    "neverthrow": "^8.2.0",
    "uiohook-napi": "^1.5.5"
  }
}
